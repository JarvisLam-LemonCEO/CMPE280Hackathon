rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function eventInvitePath(eventId, uid) {
      return /databases/$(database)/documents/eventInvites/$(eventId + "_" + uid);
    }

    function hasPendingEventInvite(eventId, uid) {
      return exists(eventInvitePath(eventId, uid))
             && get(eventInvitePath(eventId, uid)).data.status == "pending";
    }

    function isEventPhotoOwner(eventId, photoId) {
      return exists(/databases/$(database)/documents/eventPhotos/$(photoId))
             && get(/databases/$(database)/documents/eventPhotos/$(photoId)).data.eventId == eventId
             && get(/databases/$(database)/documents/eventPhotos/$(photoId)).data.ownerUid == request.auth.uid;
    }

    function onlySharedWithChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['sharedWith']);
    }

    function userAddsSelfToSharedWith() {
      return resource.data.isShared == true
             && !(request.auth.uid in resource.data.sharedWith)
             && request.auth.uid in request.resource.data.sharedWith
             && request.resource.data.sharedWith.hasAll(resource.data.sharedWith)
             && request.resource.data.sharedWith.size() == resource.data.sharedWith.size() + 1;
    }

    function userRemovesSelfFromSharedWith() {
      return request.auth.uid in resource.data.sharedWith
             && !(request.auth.uid in request.resource.data.sharedWith)
             && resource.data.sharedWith.hasAll(request.resource.data.sharedWith)
             && request.resource.data.sharedWith.size() == resource.data.sharedWith.size() - 1;
    }

    function canUpdateOwnSharedWithAccess() {
      return request.auth != null
             && onlySharedWithChanged()
             && (userAddsSelfToSharedWith() || userRemovesSelfFromSharedWith());
    }

    match /users/{uid} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }

    match /uploads/{uploadId} {
      allow read: if resource.data.isShared == true
                  || (request.auth != null
                  && (resource.data.ownerUid == request.auth.uid
                  || request.auth.uid in resource.data.sharedWith));
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid;
      allow update: if (request.auth != null
                    && resource.data.ownerUid == request.auth.uid)
                    || canUpdateOwnSharedWithAccess();
      allow delete: if request.auth != null
                    && resource.data.ownerUid == request.auth.uid;
    }

    match /albums/{albumId} {
      allow read, update, delete: if request.auth != null
                    && resource.data.ownerUid == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid;
    }

    match /albumPhotos/{albumPhotoId} {
      allow read, update, delete: if request.auth != null
                    && resource.data.ownerUid == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid;
    }

    match /events/{eventId} {
      allow read: if request.auth != null
                    && request.auth.uid in resource.data.memberUids;
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid
                    && request.auth.uid in request.resource.data.memberUids;
      allow update: if request.auth != null
                    && (
                      resource.data.ownerUid == request.auth.uid
                      || (
                        hasPendingEventInvite(eventId, request.auth.uid)
                        && !(request.auth.uid in resource.data.memberUids)
                        && request.auth.uid in request.resource.data.memberUids
                        && request.resource.data.memberUids.hasAll(resource.data.memberUids)
                        && request.resource.data.memberUids.size() == resource.data.memberUids.size() + 1
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids', 'updatedAt'])
                      )
                      || (
                        isEventPhotoOwner(eventId, request.resource.data.lastDeletedPhotoId)
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['photoCount', 'coverPhotoUrl', 'lastDeletedPhotoId', 'updatedAt'])
                        && request.resource.data.photoCount == resource.data.photoCount - 1
                      )
                    );
      allow delete: if request.auth != null
                    && resource.data.ownerUid == request.auth.uid;
    }

    match /eventInvites/{inviteId} {
      allow read: if request.auth != null
                    && (resource.data.ownerUid == request.auth.uid
                    || resource.data.recipientUid == request.auth.uid);
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid
                    && request.resource.data.status == "pending"
                    && inviteId == request.resource.data.eventId + "_" + request.resource.data.recipientUid
                    && get(/databases/$(database)/documents/events/$(request.resource.data.eventId)).data.ownerUid == request.auth.uid;
      allow update: if request.auth != null
                    && (
                      (
                        resource.data.ownerUid == request.auth.uid
                        && request.resource.data.status == "pending"
                        && inviteId == request.resource.data.eventId + "_" + request.resource.data.recipientUid
                        && get(/databases/$(database)/documents/events/$(request.resource.data.eventId)).data.ownerUid == request.auth.uid
                      )
                      || (
                        resource.data.recipientUid == request.auth.uid
                        && resource.data.status == "pending"
                        && request.resource.data.status in ["accepted", "rejected"]
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'respondedAt', 'updatedAt'])
                      )
                    );
      allow delete: if request.auth != null
                    && resource.data.ownerUid == request.auth.uid;
    }

    match /eventPhotos/{photoId} {
      allow read: if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.memberUids;
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid
                    && request.auth.uid in get(/databases/$(database)/documents/events/$(request.resource.data.eventId)).data.memberUids;
      allow update: if request.auth != null
                    && (resource.data.ownerUid == request.auth.uid
                    || get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.ownerUid == request.auth.uid)
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'subtitle', 'updatedAt']);
      allow delete: if request.auth != null
                    && (resource.data.ownerUid == request.auth.uid
                    || get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.ownerUid == request.auth.uid);
    }

    match /eventVotes/{voteId} {
      allow read: if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.memberUids;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.auth.uid in get(/databases/$(database)/documents/events/$(request.resource.data.eventId)).data.memberUids;
      allow update: if false;
      allow delete: if request.auth != null
                    && (resource.data.uid == request.auth.uid
                    || isEventPhotoOwner(resource.data.eventId, resource.data.photoId)
                    || get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.ownerUid == request.auth.uid);
    }

    match /videos/{videoId} {
      allow read: if resource.data.isShared == true
                    || (request.auth != null
                    && (resource.data.ownerUid == request.auth.uid
                    || request.auth.uid in resource.data.sharedWith));
      allow update: if (request.auth != null
                    && resource.data.ownerUid == request.auth.uid)
                    || canUpdateOwnSharedWithAccess();
      allow delete: if request.auth != null
                    && resource.data.ownerUid == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid;
    }

    match /comments/{commentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.authorUid == request.auth.uid;
      allow update: if false;
      allow delete: if request.auth != null
                    && resource.data.authorUid == request.auth.uid;
    }

    match /likes/{likeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;
    }
  }
}
